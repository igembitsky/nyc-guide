---
import BaseLayout from '../layouts/BaseLayout.astro';
import TipCallout from '../components/TipCallout.astro';
import { bonusItems } from '../data/routes';

const base = import.meta.env.BASE_URL;

const categories = [
  { id: 'museums', label: 'Museums', color: 'var(--accent-blue)' },
  { id: 'experiences', label: 'Unique Experiences', color: 'var(--accent-purple)' },
  { id: 'neighborhoods', label: 'Neighborhoods & Day Trips', color: 'var(--accent-green)' },
];
---

<BaseLayout title="Museums & Day Trips">
  <main class="bonus-page">
    <div class="bonus-header">
      <a href={`${base}`} class="bonus-back">&lsaquo; All Routes</a>
      <div class="bonus-label">BONUS</div>
      <h1 class="bonus-title">Museums &<br>Day Trips</h1>
      <p class="bonus-subtitle">Not part of the main walks, but worth your time if you've got it.</p>
    </div>

    {categories.map((cat) => {
      const items = bonusItems.filter(b => b.category === cat.id);
      if (items.length === 0) return null;
      return (
        <section class="bonus-section">
          <h2 class="bonus-section-title" style={`color: ${cat.color}`}>{cat.label}</h2>
          {items.map((item) => {
            const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${item.lat},${item.lng}&travelmode=transit`;
            const paras = item.commentary.split('\n').filter((p: string) => p.trim());
            return (
              <div class="bonus-card">
                <h3 class="bonus-card-name">{item.name}</h3>
                <div class="bonus-card-commentary">
                  {paras.map((p: string) => <p>{p}</p>)}
                </div>
                <TipCallout tip={item.tip} color={cat.color} />
                <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="bonus-maps-btn">
                  Open in Google Maps
                </a>
              </div>
            );
          })}
        </section>
      );
    })}
  </main>
</BaseLayout>

<style>
  .bonus-page {
    max-width: 600px;
    margin: 0 auto;
    padding-bottom: 100px;
  }

  .bonus-header {
    padding: 48px 20px 20px;
  }

  .bonus-back {
    font-size: 13px;
    color: var(--accent-gray);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 16px;
    animation: slideInLeft 0.4s var(--ease-out) both;
  }

  .bonus-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent-gray);
    letter-spacing: 2px;
    margin-bottom: 6px;
    animation: fadeInUp 0.4s var(--ease-out) 0.05s both;
  }

  .bonus-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 9vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.0;
    margin-bottom: 8px;
    animation: fadeInUp 0.5s var(--ease-out) 0.1s both;
  }

  .bonus-subtitle {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.4;
    animation: fadeInUp 0.5s var(--ease-out) 0.15s both;
  }

  .bonus-section {
    padding: 0 16px;
    margin-top: 32px;
  }

  .bonus-section-title {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .bonus-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }

  .bonus-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .bonus-section-title.visible {
    animation: slideInLeft 0.4s var(--ease-out) both;
  }

  .bonus-card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 12px;
  }

  .bonus-card-commentary p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .bonus-maps-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    background: var(--primary-dim);
    color: var(--primary);
    font-size: 12px;
    font-weight: 600;
    transition: opacity var(--duration-fast);
  }

  .bonus-maps-btn:hover { opacity: 0.8; }
</style>

<script>
  const bonusObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        bonusObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.bonus-card, .bonus-section-title').forEach(el => bonusObserver.observe(el));
</script>
